# === Sureline Voice Agent — Environment Variables ===

# ── STT + TTS: Sarvam AI (primary provider) ─────────────────────
# Get your key at https://dashboard.sarvam.ai
SARVAM_API_KEY=

# Sarvam model overrides (optional — defaults shown)
SARVAM_STT_MODEL=saaras:v3
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_TTS_VOICE=shubh

# ── TTS Provider Toggle ──────────────────────────────────────────
# "sarvam"      → use Sarvam TTS  (default)
# "elevenlabs"  → use ElevenLabs TTS (backup)
TTS_PROVIDER=sarvam

# ── TTS Backup: ElevenLabs ───────────────────────────────────────
# Used when TTS_PROVIDER=elevenlabs
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ── LLM: Ollama (local, no key needed) ──────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
# qwen2.5:1.5b = ~1 GB, ultra-fast, solid tool calling
# qwen2.5:3b   = ~2 GB, slower but higher quality
OLLAMA_MODEL=qwen2.5:1.5b

# ── Logging ─────────────────────────────────────────────────────
LOG_LEVEL=INFO
